# Telegram Bot Token (get from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# OpenAI API Key (for audio transcription via Whisper)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API Key (for invoice data extraction via Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google API credentials (OAuth2 JSON file downloaded from Google Cloud Console)
GOOGLE_CREDENTIALS_PATH=config/credentials/google_credentials.json
# Stored token after first authorization (auto-generated)
GOOGLE_TOKEN_PATH=config/credentials/google_token.json

# Google Spreadsheet ID (from the URL: docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit)
SPREADSHEET_ID=your_spreadsheet_id_here
# Name of the worksheet/tab inside the spreadsheet
SPREADSHEET_NAME=Facturas
