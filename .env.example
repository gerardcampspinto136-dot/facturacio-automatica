# Telegram Bot Token (get from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Speech-to-text: set ONE of these (Groq is free, recommended for testing)
# Groq → https://console.groq.com → API Keys
GROQ_API_KEY=your_groq_api_key_here
# OpenAI → https://platform.openai.com/api-keys (paid alternative)
OPENAI_API_KEY=

# Anthropic API Key (for invoice data extraction via Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google API credentials (OAuth2 JSON file downloaded from Google Cloud Console)
GOOGLE_CREDENTIALS_PATH=config/credentials/google_credentials.json
# Stored token after first authorization (auto-generated)
GOOGLE_TOKEN_PATH=config/credentials/google_token.json

# Google Spreadsheet ID (from the URL: docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit)
SPREADSHEET_ID=your_spreadsheet_id_here
# Name of the worksheet/tab inside the spreadsheet
SPREADSHEET_NAME=Facturas

# ── Review web page (only needed in "manual" review mode) ──────────────────
# Google "Web application" OAuth client for the reviewer login (SEPARATE from the
# Desktop client above). Add {base_url}/auth/callback as an authorized redirect URI.
WEB_OAUTH_CLIENT_ID=
WEB_OAUTH_CLIENT_SECRET=
# Random secret used to sign the login session cookie (any long random string).
SESSION_SECRET=change-me-to-a-long-random-string
# Set to 1 to bypass Google login for LOCAL testing only (never in production).
WEB_DEV_NO_AUTH=
